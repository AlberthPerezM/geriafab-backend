GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models/gemini-2.5-flash:generateContent
# Opcional: dejalo vacio o en 0 para no enviar limite de salida a Gemini.
GEMINI_MAX_OUTPUT_TOKENS=
GEMINI_TEMPERATURE=0.5

# Clave privada usada solo por el backend para buscar videos.
YOUTUBE_API_KEY=your-youtube-api-key

DATABASE_URL=postgresql://postgres:123@localhost:5432/geriafab_bd
CONVERSATION_SESSION_ID=default
# 0 = historial guardado sin vencimiento. MAX_HISTORY_MESSAGES limita solo lo enviado a Gemini.
HISTORY_TTL_SECONDS=0
MAX_HISTORY_MESSAGES=12
